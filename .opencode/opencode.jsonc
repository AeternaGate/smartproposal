{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [
      ".opencode/skills",
      "~/.config/opencode/skills",
      "~/.config/opencode/superpowers/skills"
    ]
  },
  "references": {
    "design": {
      "path": "docs/superpowers/specs",
      "description": "Design documents and specs — use for architecture and implementation decisions"
    }
  },
  "mcp": {
    "magicuidesign": {
      "type": "local",
      "command": ["npx", "-y", "@magicuidesign/mcp@latest"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true,
      "env": { "PLAYWRIGHT_BROWSERS_PATH": "0" }
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=laeuwzpqmqjwdicfhqld",
      "enabled": true
    },
    "vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com",
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  },
  "permission": {
    "bash": {
      "npm *": "allow",
      "npx *": "allow",
      "git *": "allow",
      "node *": "allow",
      "playwright*": "allow",
      "*": "ask"
    },
    "read": "allow",
    "edit": "allow"
  }
}
